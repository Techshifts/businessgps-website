# BusinessGPS.ai Environment Variables
# Copy this file to .env and fill in your values

# ===================
# STRIPE (Required)
# ===================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs - create products first in Stripe Dashboard
# Products > Add product > Copy price ID
STRIPE_PRICE_ATHENA_STD=price_xxx    # Athena Standard £67
STRIPE_PRICE_ATHENA_PREM=price_xxx   # Athena Premium £297
STRIPE_PRICE_SR30=price_xxx          # Start Right-30 £1,997
STRIPE_PRICE_TP90=price_xxx          # Throughput-90 £5,997
STRIPE_PRICE_OPSMAX=price_xxx        # OpsMax-360 £15,000

# ===================
# SUPABASE (Required)
# ===================
# Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=xxx

# ===================
# AWEBER (Required for email)
# ===================
# OAuth credentials from: https://labs.aweber.com/apps
AWEBER_ACCOUNT_ID=xxx
AWEBER_CLIENT_ID=xxx                  # OAuth app Client ID
AWEBER_CLIENT_SECRET=xxx              # OAuth app Client Secret
AWEBER_LIST_ID_LEADS=xxx              # For TCM report downloads
AWEBER_LIST_ID_CUSTOMERS=xxx          # For purchase confirmations
AWEBER_LIST_ID_ENTERPRISE=xxx         # For OpsMax inquiries

# Token store - MUST point to production Supabase (shared across environments)
# Tokens auto-refresh and are stored in the api_tokens table
AWEBER_TOKEN_STORE_URL=https://rqffoadqydlebipkeckw.supabase.co
AWEBER_TOKEN_STORE_KEY=xxx            # Production Supabase service role key

# ===================
# HUBSPOT (Required for CRM)
# ===================
# Get from: Settings > Integrations > Private Apps
HUBSPOT_API_KEY=xxx
HUBSPOT_PIPELINE_PRODUCTS=xxx              # Deal pipeline ID for standard products
HUBSPOT_PIPELINE_ENTERPRISE=xxx            # Deal pipeline ID for OpsMax/enterprise
HUBSPOT_STAGE_CLOSEDWON_PRODUCTS=xxx       # "Closed Won" stage ID in Products pipeline
HUBSPOT_STAGE_CLOSEDWON_ENTERPRISE=xxx     # "Closed Won" stage ID in Enterprise pipeline

# ===================
# ANALYTICS (Optional)
# ===================
# Get from: https://analytics.google.com
# Replace GA4_TRACKING_ID in HTML files with this value
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
